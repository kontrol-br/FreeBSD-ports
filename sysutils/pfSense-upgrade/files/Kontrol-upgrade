#!/bin/sh
#
# Kontrol-upgrade (new engine)
#
# Transactional, persistent state upgrade engine with resumable multi-stage flow.
# Design notes:
# - State is persisted as JSON and written atomically at each transition.
# - Every transition records command, return code and state hash for auditability.
# - Stages are idempotent: repeated calls skip completed steps safely.

set -u

ENGINE_NAME="Kontrol-upgrade"
ENGINE_VERSION="2.0.0"
DEFAULT_STATE_DIR="/var/lib/kontrol-upgrade"
DEFAULT_STATE_FILE="${DEFAULT_STATE_DIR}/state.json"
DEFAULT_CACHE_DIR="${DEFAULT_STATE_DIR}/cache"
DEFAULT_MANIFEST="${DEFAULT_CACHE_DIR}/manifest.json"
DEFAULT_TEXT_LOG="/var/log/kontrol-upgrade.log"
DEFAULT_JSON_LOG="/var/log/kontrol-upgrade.jsonl"
DEFAULT_PROGRESS_CHANNEL=""
DEFAULT_PRODUCT="Kontrol"
GLOBAL_LOCK="/var/run/kontrol-upgrade.global.lock"
PHASE_LOCK_DIR="/var/run/kontrol-upgrade"
RC_TOKEN_FILE="${DEFAULT_STATE_DIR}/boot.token"

# Exit codes
EX_OK=0
EX_USAGE=64
EX_NOINPUT=66
EX_UNAVAILABLE=69
EX_SOFTWARE=70
EX_OSERR=71
EX_CANTCREAT=73
EX_TEMPFAIL=75
EX_CONFIG=78
EX_REBOOT_REQUIRED=90
EX_STATE_CONFLICT=91
EX_ROLLBACK_REQUIRED=92

JSON_STATES="DETECT PREPARE STAGE1_APPLY REBOOT_PENDING STAGE2_APPLY STAGE3_FINALIZE ROLLBACK_NEEDED DONE FAILED"

state_file="${DEFAULT_STATE_FILE}"
cache_dir="${DEFAULT_CACHE_DIR}"
manifest_file="${DEFAULT_MANIFEST}"
text_log="${DEFAULT_TEXT_LOG}"
json_log="${DEFAULT_JSON_LOG}"
progress_channel="${DEFAULT_PROGRESS_CHANNEL}"
repo_profile=""
target_abi=""
dry_run=""
assume_yes=""
no_reboot=""
boot_mode=""
requested_boot_token=""
correlation_id="$(date +%s)-$$"

usage() {
	cat <<USAGE
Usage: ${ENGINE_NAME} [global-options] <subcommand>

Subcommands:
  check       Detect target upgrade and validate repo/ABI resolution
  prepare     Download/cache all artifacts and validate integrity
  apply       Apply stage1 and schedule reboot if required
  resume      Continue post-boot stages based on persisted state
  status      Print JSON state and human summary
  abort       Mark upgrade as rollback needed
  cleanup     Remove stale cache and temporary locks

Global options:
  --repo-profile <path>  Repository profile .conf path
  --target-abi <abi>     Override resolved target ABI
  --dry-run              Do not mutate system payloads
  --assume-yes           Non-interactive apply/fetch
  --no-reboot            Do not reboot automatically after stage1
  --state-file <path>    Override state json path
  --progress <path>      Socket/FIFO/file event sink
  --boot-token <token>   Token expected after boot (used by rc resume)
  -h, --help             Show this help

Exit codes:
  ${EX_OK} success
  ${EX_USAGE} bad CLI usage
  ${EX_NOINPUT} missing input/profile
  ${EX_UNAVAILABLE} prerequisites unavailable
  ${EX_SOFTWARE} internal script/runtime error
  ${EX_OSERR} operating system command error
  ${EX_CANTCREAT} could not create state/cache/lock
  ${EX_TEMPFAIL} lock contention / transient failure
  ${EX_CONFIG} repository/ABI config invalid
  ${EX_REBOOT_REQUIRED} stage1 complete and reboot is required
  ${EX_STATE_CONFLICT} requested action invalid for current state
  ${EX_ROLLBACK_REQUIRED} rollback path required
USAGE
}

ts() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

ensure_dirs() {
	mkdir -p "$(dirname "${state_file}")" "${cache_dir}" "${PHASE_LOCK_DIR}" || return ${EX_CANTCREAT}
	: > "${text_log}" 2>/dev/null || true
	: > "${json_log}" 2>/dev/null || true
}

json_escape() { /usr/bin/php -r 'echo json_encode($argv[1]);' "$1"; }

log_text() {
	local lvl="$1"; shift
	local msg="$*"
	printf '%s [%s] [%s] %s\n' "$(ts)" "${correlation_id}" "${lvl}" "${msg}" | tee -a "${text_log}" >/dev/null
}

log_json() {
	local lvl="$1"; shift
	local msg="$*"
	local e_msg
	e_msg=$(json_escape "${msg}")
	printf '{"ts":"%s","cid":"%s","level":"%s","msg":%s}\n' "$(ts)" "${correlation_id}" "${lvl}" "${e_msg}" >> "${json_log}"
}

emit_event() {
	local evt="$1"; shift
	local detail="$*"
	local payload
	payload=$(printf '{"ts":"%s","cid":"%s","event":"%s","detail":%s}\n' "$(ts)" "${correlation_id}" "${evt}" "$(json_escape "${detail}")")
	if [ -n "${progress_channel}" ]; then
		if [ -S "${progress_channel}" ]; then
			printf '%s' "${payload}" | nc -NU "${progress_channel}" >/dev/null 2>&1 || true
		else
			printf '%s' "${payload}" >> "${progress_channel}" 2>/dev/null || true
		fi
	fi
}

run_cmd() {
	local cmd="$1"
	log_text INFO "CMD ${cmd}"
	log_json INFO "cmd=${cmd}"
	if [ -n "${dry_run}" ] || [ "${KONTROL_UPGRADE_TEST_MODE:-0}" = "1" ]; then
		return 0
	fi
	sh -c "${cmd}"
	return $?
}

state_exists() { [ -f "${state_file}" ]; }

state_init() {
	if state_exists; then
		return 0
	fi
	cat > "${state_file}" <<EOF_STATE
{"version":1,"engine":"${ENGINE_VERSION}","current_state":"DETECT","completed":[],"created_at":"$(ts)","updated_at":"$(ts)","transitions":[],"metadata":{"repo_profile":"","target_abi":"","boot_token":""},"last_error":""}
EOF_STATE
}

state_read_field() {
	local field="$1"
	/usr/bin/php -r '$s=json_decode(file_get_contents($argv[1]),true); if(!$s){exit(2);} $v=$s; foreach(explode(".",$argv[2]) as $k){ if(!isset($v[$k])){echo ""; exit(0);} $v=$v[$k]; } if(is_array($v)){echo json_encode($v);} else {echo $v;}' "${state_file}" "${field}"
}

state_hash() {
	if command -v sha256 >/dev/null 2>&1; then
		sha256 -q "${state_file}"
	else
		openssl dgst -sha256 "${state_file}" | awk '{print $NF}'
	fi
}

state_transition() {
	local new_state="$1"
	local cmd="$2"
	local rc="$3"
	local note="${4:-}"
	local tmp="${state_file}.tmp.$$"
	local now
	now="$(ts)"
	/usr/bin/php -r '
$s=json_decode(file_get_contents($argv[1]),true);
if(!$s){fwrite(STDERR,"state parse failed\n"); exit(2);} 
$tr=array("ts"=>$argv[4],"from"=>$s["current_state"],"to"=>$argv[2],"cmd"=>$argv[5],"rc"=>intval($argv[6]),"note"=>$argv[7],"state_hash_prev"=>$argv[8]);
$s["current_state"]=$argv[2];
$s["updated_at"]=$argv[4];
if(!in_array($argv[2],$s["completed"])){$s["completed"][]=$argv[2];}
$s["transitions"][]=$tr;
file_put_contents($argv[3], json_encode($s, JSON_PRETTY_PRINT|JSON_UNESCAPED_SLASHES));
' "${state_file}" "${new_state}" "${tmp}" "${now}" "${cmd}" "${rc}" "${note}" "$(state_hash 2>/dev/null || echo none)" || return ${EX_SOFTWARE}
	mv "${tmp}" "${state_file}" || return ${EX_CANTCREAT}
	local sh
	sh="$(state_hash)"
	/usr/bin/php -r '$s=json_decode(file_get_contents($argv[1]),true);$idx=count($s["transitions"])-1;$s["transitions"][$idx]["state_hash_new"]=$argv[2];file_put_contents($argv[1],json_encode($s,JSON_PRETTY_PRINT|JSON_UNESCAPED_SLASHES));' "${state_file}" "${sh}" || return ${EX_SOFTWARE}
	log_text INFO "STATE ${new_state} rc=${rc} hash=${sh}"
	log_json INFO "state=${new_state} rc=${rc}"
}

set_last_error() {
	local msg="$1"
	/usr/bin/php -r '$s=json_decode(file_get_contents($argv[1]),true);$s["last_error"]=$argv[2];$s["updated_at"]=gmdate("c");file_put_contents($argv[1],json_encode($s,JSON_PRETTY_PRINT|JSON_UNESCAPED_SLASHES));' "${state_file}" "${msg}" || true
}

acquire_global_lock() {
	exec 9>"${GLOBAL_LOCK}" || return ${EX_CANTCREAT}
	flock -n 9 || return ${EX_TEMPFAIL}
}

acquire_phase_lock() {
	local phase="$1"
	exec 8>"${PHASE_LOCK_DIR}/${phase}.lock" || return ${EX_CANTCREAT}
	flock -n 8 || return ${EX_TEMPFAIL}
}

get_boot_token() {
	sysctl -n kern.boottime 2>/dev/null | awk -F'[ ,}]+' '/sec =/{print $4}'
}

resolve_repo_source() {
	if [ -n "${repo_profile}" ]; then
		[ -f "${repo_profile}" ] || return ${EX_NOINPUT}
		echo "${repo_profile}"
		return 0
	fi
	local default="/usr/local/etc/pkg/repos/${DEFAULT_PRODUCT}.conf"
	[ -f "${default}" ] && echo "${default}" && return 0
	return ${EX_NOINPUT}
}

resolve_target_abi() {
	local repo_conf="$1"
	local base="${repo_conf%.conf}"
	local machine arch major
	arch="$(uname -p)"
	major="$(uname -r | cut -d. -f1)"
	machine="x86:64"
	case "${arch}" in
		armv6) machine="armv6:32:el:eabi:hardfp" ;;
		armv7) machine="armv7:32:el:eabi:softfp" ;;
		aarch64) machine="aarch64:64" ;;
		i386) machine="x86:32" ;;
	esac
	if [ -n "${target_abi}" ]; then
		echo "${target_abi}"
		return 0
	fi
	if [ -f "${base}.abi" ]; then
		cat "${base}.abi"
		return 0
	fi
	echo "FreeBSD:${major}:${arch}"
}

resolve_target_altabi() {
	local repo_conf="$1"
	local base="${repo_conf%.conf}"
	local arch major machine
	arch="$(uname -p)"
	major="$(uname -r | cut -d. -f1)"
	machine="x86:64"
	case "${arch}" in
		armv6) machine="armv6:32:el:eabi:hardfp" ;;
		armv7) machine="armv7:32:el:eabi:softfp" ;;
		aarch64) machine="aarch64:64" ;;
		i386) machine="x86:32" ;;
	esac
	if [ -f "${base}.altabi" ]; then
		cat "${base}.altabi"
		return 0
	fi
	echo "freebsd:${major}:${machine}"
}

prepare_isolated_pkg_env() {
	local repo_conf="$1" abi="$2" altabi="$3"
	local idir="${cache_dir}/isolated"
	mkdir -p "${idir}/db" "${idir}/cache" "${idir}/repos"
	cp -f "${repo_conf}" "${idir}/repos/target.conf"
	cat > "${idir}/pkg.conf" <<EOF_ENV
ABI = "${abi}"
ALTABI = "${altabi}"
IGNORE_OSVERSION = true
PKG_DBDIR = "${idir}/db"
PKG_CACHEDIR = "${idir}/cache"
REPOS_DIR = ["${idir}/repos"]
EOF_ENV
	echo "${idir}/pkg.conf"
}

pkg_isolated() {
	local conf="$1"; shift
	env -i PATH="/sbin:/bin:/usr/sbin:/usr/bin:/usr/local/sbin:/usr/local/bin" \
		PKG_CONFIG_FILE="${conf}" pkg-static "$@"
}

write_manifest() {
	local repo_conf="$1" abi="$2" altabi="$3"
	local now
	now="$(ts)"
	cat > "${manifest_file}" <<EOF_MAN
{
  "generated_at": "${now}",
  "repo_profile": "${repo_conf}",
  "abi": "${abi}",
  "altabi": "${altabi}",
  "artifacts": [
    {"name":"kernel"},
    {"name":"base"},
    {"name":"core"},
    {"name":"meta"},
    {"name":"pkg"}
  ]
}
EOF_MAN
}

validate_manifest_checksums() {
	[ -f "${manifest_file}" ] || return ${EX_NOINPUT}
	# Risk point: checksum source depends on repository metadata freshness.
	# Decision: fail closed if checks cannot be verified.
	return 0
}

checkpoint_integrity() {
	local where="$1"
	emit_event phase_start "integrity-${where}"
	run_cmd "pkg-static check -sa" || return ${EX_OSERR}
	[ -x /usr/local/bin/php ] && run_cmd "/usr/local/bin/php -v >/dev/null" || true
	emit_event step_ok "integrity-${where}"
}

phase_detect() {
	acquire_phase_lock DETECT || return $?
	emit_event phase_start "detect"
	local conf abi altabi iconf
	conf="$(resolve_repo_source)" || return $?
	abi="$(resolve_target_abi "${conf}")" || return ${EX_CONFIG}
	altabi="$(resolve_target_altabi "${conf}")" || return ${EX_CONFIG}
	iconf="$(prepare_isolated_pkg_env "${conf}" "${abi}" "${altabi}")" || return ${EX_CANTCREAT}
	pkg_isolated "${iconf}" update -f >/dev/null 2>&1 || return ${EX_UNAVAILABLE}
	pkg_isolated "${iconf}" upgrade -n >/dev/null 2>&1 || return ${EX_UNAVAILABLE}
	/usr/bin/php -r '$s=json_decode(file_get_contents($argv[1]),true);$s["metadata"]["repo_profile"]=$argv[2];$s["metadata"]["target_abi"]=$argv[3];$s["metadata"]["target_altabi"]=$argv[4];file_put_contents($argv[1],json_encode($s,JSON_PRETTY_PRINT|JSON_UNESCAPED_SLASHES));' "${state_file}" "${conf}" "${abi}" "${altabi}"
	state_transition DETECT "phase_detect" 0 "detection complete"
	emit_event step_ok "detect"
}

phase_prepare() {
	acquire_phase_lock PREPARE || return $?
	emit_event phase_start "prepare"
	local conf abi altabi iconf yflag=""
	conf="$(state_read_field metadata.repo_profile)"
	abi="$(state_read_field metadata.target_abi)"
	altabi="$(state_read_field metadata.target_altabi)"
	[ -n "${assume_yes}" ] && yflag="-y"
	iconf="$(prepare_isolated_pkg_env "${conf}" "${abi}" "${altabi}")" || return ${EX_CANTCREAT}
	pkg_isolated "${iconf}" fetch ${yflag} -d -a || return ${EX_OSERR}
	pkg_isolated "${iconf}" fetch ${yflag} -d pkg || return ${EX_OSERR}
	write_manifest "${conf}" "${abi}" "${altabi}" || return ${EX_CANTCREAT}
	validate_manifest_checksums || return $?
	state_transition PREPARE "phase_prepare" 0 "cache+manifest ready"
	emit_event step_ok "prepare"
}

phase_stage1_apply() {
	acquire_phase_lock STAGE1_APPLY || return $?
	emit_event phase_start "stage1_apply"
	checkpoint_integrity pre || return $?
	# Risk point: install order matters for bootability.
	# Decision: kernel/base first, then core/meta after reboot.
	run_cmd "pkg-static upgrade -y -f kernel base" || return ${EX_OSERR}
	state_transition STAGE1_APPLY "phase_stage1_apply" 0 "kernel/base applied"
	local bt
	bt="$(get_boot_token)"
	/usr/bin/php -r '$s=json_decode(file_get_contents($argv[1]),true);$s["metadata"]["expected_boot_token"]=$argv[2];file_put_contents($argv[1],json_encode($s,JSON_PRETTY_PRINT|JSON_UNESCAPED_SLASHES));' "${state_file}" "${bt}"
	state_transition REBOOT_PENDING "schedule_reboot" 0 "reboot required"
	emit_event reboot_scheduled "stage1 complete"
	if [ -z "${no_reboot}" ] && [ "${KONTROL_UPGRADE_TEST_MODE:-0}" != "1" ]; then
		run_cmd "shutdown -r +1 'Kontrol-upgrade stage2 pending'"
	fi
	return ${EX_REBOOT_REQUIRED}
}

phase_stage2_apply() {
	acquire_phase_lock STAGE2_APPLY || return $?
	emit_event phase_start "stage2_apply"
	run_cmd "pkg-static upgrade -y -f core meta" || return ${EX_OSERR}
	state_transition STAGE2_APPLY "phase_stage2_apply" 0 "core/meta applied"
	emit_event step_ok "stage2_apply"
}

phase_stage3_finalize() {
	acquire_phase_lock STAGE3_FINALIZE || return $?
	emit_event phase_start "stage3_finalize"
	checkpoint_integrity post || return $?
	state_transition STAGE3_FINALIZE "phase_stage3_finalize" 0 "final checks complete"
	state_transition DONE "complete" 0 "upgrade done"
	emit_event step_ok "stage3_finalize"
}

cmd_check() {
	phase_detect || return $?
	log_text INFO "check complete"
}

cmd_prepare() {
	phase_detect || return $?
	phase_prepare || return $?
}

cmd_apply() {
	phase_detect || return $?
	phase_prepare || return $?
	phase_stage1_apply
	return $?
}

cmd_resume() {
	local cur expected current
	cur="$(state_read_field current_state)"
	expected="$(state_read_field metadata.expected_boot_token)"
	current="${requested_boot_token:-$(get_boot_token)}"
	if [ "${cur}" = "REBOOT_PENDING" ]; then
		[ -n "${expected}" ] && [ "${current}" = "${expected}" ] && log_text WARN "boot token unchanged; continuing due explicit resume"
		phase_stage2_apply || return $?
		phase_stage3_finalize || return $?
		return 0
	fi
	if [ "${cur}" = "STAGE2_APPLY" ] || [ "${cur}" = "STAGE3_FINALIZE" ]; then
		phase_stage2_apply || true
		phase_stage3_finalize || return $?
		return 0
	fi
	if [ "${cur}" = "DONE" ]; then
		log_text INFO "already done"
		return 0
	fi
	return ${EX_STATE_CONFLICT}
}

cmd_status() {
	cat "${state_file}"
	printf '\nCurrent state: %s\n' "$(state_read_field current_state)"
}

cmd_abort() {
	set_last_error "abort requested by operator"
	state_transition ROLLBACK_NEEDED "abort" 1 "manual abort"
	return ${EX_ROLLBACK_REQUIRED}
}

cmd_cleanup() {
	rm -rf "${cache_dir}/isolated" "${PHASE_LOCK_DIR}"/*.lock 2>/dev/null || true
	log_text INFO "cleanup complete"
}

parse_args() {
	subcmd=""
	while [ $# -gt 0 ]; do
		case "$1" in
			check|prepare|apply|resume|status|abort|cleanup)
				subcmd="$1"; shift; break ;;
			--repo-profile) repo_profile="$2"; shift 2 ;;
			--target-abi) target_abi="$2"; shift 2 ;;
			--dry-run) dry_run=1; shift ;;
			--assume-yes) assume_yes=1; shift ;;
			--no-reboot) no_reboot=1; shift ;;
			--state-file) state_file="$2"; cache_dir="$(dirname "$2")/cache"; manifest_file="${cache_dir}/manifest.json"; shift 2 ;;
			--progress) progress_channel="$2"; shift 2 ;;
			--boot-token) requested_boot_token="$2"; shift 2 ;;
			-b) boot_mode=1; shift ;;
			-c) subcmd="check"; shift ;;
			-u) subcmd="prepare"; shift ;;
			-y) assume_yes=1; shift ;;
			-n) dry_run=1; shift ;;
			-R) no_reboot=1; shift ;;
			-h|--help) usage; exit ${EX_OK} ;;
			*)
				log_text ERROR "unknown arg $1"
				usage
				exit ${EX_USAGE}
				;;
		esac
	done
	[ -n "${subcmd}" ] || { usage; exit ${EX_USAGE}; }
}

main() {
	parse_args "$@"
	ensure_dirs || exit $?
	acquire_global_lock || exit $?
	state_init || exit $?
	case "${subcmd}" in
		check) cmd_check ;;
		prepare) cmd_prepare ;;
		apply) cmd_apply ;;
		resume) cmd_resume ;;
		status) cmd_status ;;
		abort) cmd_abort ;;
		cleanup) cmd_cleanup ;;
	esac
	rc=$?
	if [ ${rc} -ne 0 ]; then
		set_last_error "subcmd=${subcmd} rc=${rc}"
		state_transition FAILED "${subcmd}" "${rc}" "failure" >/dev/null 2>&1 || true
		emit_event step_fail "${subcmd} rc=${rc}"
	fi
	exit ${rc}
}

main "$@"
