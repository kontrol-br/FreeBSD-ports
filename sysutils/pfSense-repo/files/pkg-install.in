#!/bin/sh

if [ "${2}" != "POST-INSTALL" ]; then
	exit 0
fi

# Workaround to prevent https://redmine.pfsense.org/issues/9873
if grep -q "pkg info" /etc/rc.php_ini_setup; then
	sed -i '' -e 's,pkg info,/usr/local/sbin/pkg-static info,g' \
	    /etc/rc.php_ini_setup
elif grep -q "if pkg-static info" /etc/rc.php_ini_setup; then
	sed -i '' -e 's,pkg-static info,/usr/local/sbin/pkg-static info,g' \
	    /etc/rc.php_ini_setup
fi

# Do not configure pkg repo on poudriere
if [ -f /etc/make.conf ] && grep -q 'POUDRIERE_PORTS_NAME=' /etc/make.conf; then
	exit 0
fi

REPO_PATH=/usr/local/etc/pkg/repos
REPO_CONF=${REPO_PATH}/%%PRODUCT_NAME%%.conf
REPO_SHARE_DIR=/usr/local/share/%%PRODUCT_NAME%%/pkg/repos

if [ -d "${REPO_SHARE_DIR}" ]; then
	for repo_file in "${REPO_SHARE_DIR}"/*; do
		[ -e "${repo_file}" ] || continue
		base=$(basename "${repo_file}")
		case "${base}" in
			*.conf|*.descr|*.abi|*.altabi)
				repo_name="${base%.*}"
				keep_repo=""
				for allowed_repo in %%REPO_FILES%%; do
					if [ "${repo_name}" = "${allowed_repo}" ]; then
						keep_repo=1
						break
					fi
				done
				if [ -z "${keep_repo}" ]; then
					rm -f "${repo_file}"
				fi
				;;
		esac
	done
fi

if [ ! -f "%%DEFAULT_REPO%%" ]; then
	echo "===> ERROR: Default repo conf not found!"
	exit 1
fi

if [ ! -L "${REPO_CONF}" ]; then
	if [ -f "${REPO_CONF}" ]; then
		rm -f ${REPO_CONF}
	fi
	mkdir -p ${REPO_PATH}
	ln -sf %%DEFAULT_REPO%% ${REPO_CONF}
fi

PKG_CONF="/usr/local/etc/pkg.conf"
REAL_CONF=$(readlink ${REPO_CONF})

ABI_FILE="${REAL_CONF%%.conf}.abi"
OSVERSION=$(/sbin/sysctl -n kern.osreldate)

echo "ABI_FILE=${ABI_FILE}" > ${PKG_CONF}
echo "OSVERSION=${OSVERSION}" >> ${PKG_CONF}

# Help users to fix fstab before risk moving to FreeBSD 11
if /usr/bin/grep -q -E '/dev/ad[[:digit:]]' /etc/fstab; then
	echo "===> Fixing bad /etc/fstab"
	/usr/local/sbin/ufslabels.sh commit
fi

exit 0
